# ── Camera ───────────────────────────────────────────────────
# URL from IP Webcam app on Pixel 4a (Settings > Video preferences)
CAMERA_URL=http://192.168.x.x:8080/video
STREAM_WIDTH=1280
STREAM_HEIGHT=720
STREAM_FPS=15

# ── AI Engine ────────────────────────────────────────────────
YOLO_MODEL=yolov8n.pt
FACE_MODEL=ArcFace
CONFIDENCE_THRESHOLD=0.60
PERSON_CONFIRM_SECONDS=1.0     # Seconds before running face recognition
ALERT_COOLDOWN_SECONDS=60      # Min seconds between alerts for same unknown person
MIN_PERSON_BOX_HEIGHT=120      # Min person bbox px-height to attempt recognition (lower = detect further away)

# ── Paths ────────────────────────────────────────────────────
FACES_DB_PATH=data/faces
EMBEDDINGS_PATH=data/embeddings
MODELS_PATH=engine/models
LOGS_PATH=data/logs
ALERTS_PATH=data/alerts

# ── Firebase ─────────────────────────────────────────────────
FIREBASE_CREDENTIALS_PATH=config/firebase-credentials.json
# Storage bucket is OPTIONAL — leave as the placeholder to run FCM push with
# snapshots served locally; set a real bucket to upload snapshots to Storage.
FIREBASE_STORAGE_BUCKET=your-app.appspot.com
FCM_TOKENS_PATH=data/fcm_tokens.json    # where registered device push-tokens are kept

# ── API ──────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=change-this-to-a-strong-random-secret

# ── Relay (optional — for remote access outside home WiFi) ───
RELAY_ENABLED=false
RELAY_URL=
