# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
venv/
env/
.venv/

# ── Environment ──────────────────────────────────────────────
.env
*.env.local

# ── Project meta-docs (internal, not for public repo) ────────
AGENTS.md
SKILLS.md
DESIGN.md

# ── Sensitive / Biometric data ───────────────────────────────
data/faces/*
tests/test_images/*
data/embeddings/*
data/alerts/*
data/fcm_tokens.json
!data/faces/.gitkeep
!data/embeddings/.gitkeep
!data/alerts/.gitkeep
.claude/*

# ── Firebase credentials ─────────────────────────────────────
config/firebase-credentials.json
config/*.json
app/android/app/google-services.json
app/ios/Runner/GoogleService-Info.plist

# ── AI Models (large binaries) ───────────────────────────────
engine/models/*.pt
engine/models/*.onnx
!engine/models/.gitkeep

# ── YOLOv8 auto-downloaded weights (lands in project root) ───
*.pt
*.onnx

# ── Logs ─────────────────────────────────────────────────────
data/logs/*
!data/logs/.gitkeep
*.log

# ── IDE ──────────────────────────────────────────────────────
.vscode/
.idea/
.antigravity/
*.swp

# ── OS ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Build ────────────────────────────────────────────────────
dist/
build/
*.egg-info/